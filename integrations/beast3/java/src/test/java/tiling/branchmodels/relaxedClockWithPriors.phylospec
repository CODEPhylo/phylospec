Alignment alignment = fromNexus("primate-mtDNA.nex")
Taxa taxa = taxa(alignment)
Tree tree ~ Yule(
    birthRate=1.0, taxa
)

Distribution<Vector<Rate>> dist = RelaxedClock(
    clockRate~Gamma(shape=1.0, rate=2.0),
    base=LogNormal(mean=1.0, logSd=2.0),
    tree
)
Distribution<Vector<Rate>> dist = RelaxedClock(
    clockRate~LogNormal(logMean=1, logSd=2.0),
    base=Gamma(shape=1.0, rate=2.0),
    tree
)

