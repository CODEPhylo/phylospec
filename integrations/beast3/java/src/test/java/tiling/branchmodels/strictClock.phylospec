Alignment alignment = fromNexus("primate-mtDNA.nex")
Taxa taxa = taxa(alignment)
Tree tree ~ Yule(
    birthRate=1.0, taxa
)
Distribution<Vector<Rate>> dist = StrictClock(rate=1.0, tree)

