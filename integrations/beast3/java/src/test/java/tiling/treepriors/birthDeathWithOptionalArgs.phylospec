// BirthDeath with optional samplingProbability and rootAge arguments
Real samplingProb ~ Beta(alpha=1.0, beta=1.0)
Real rootAge ~ Exponential(rate=1.0)
Alignment data = fromNexus("primate-mtDNA.nex")
Tree tree ~ BirthDeath(
    diversificationRate=1.0,
    turnover=0.5,
    samplingProbability=samplingProb,
    rootAge=rootAge,
    taxa=taxa(data)
)

