Alignment data = fromNexus("primate-mtDNA.nex")
Tree tree ~ Yule(birthRate=1.0, taxa=taxa(data))

Integer n = numBranches(tree)
Integer m = numTaxa(tree)
Integer w = numTaxa(data)
Integer k = numSites(data)

