String a = "Hallo"
String b = a + a + "Nooooo"
String c = a + -5.0
String d = 10.0 + "hallo"
String e = ":) ${a} world"
String f = "${a}"
String g = "${a}${b} ${c}"
String h = ":) \${a} world"
PositiveReal i = 3.0
Integer j = 3
Vector<Real> k = [3.0]
String l = "${i}${j}${k}"

