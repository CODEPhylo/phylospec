Alignment observedAlignment = fromNexus(
	file="alignment.nexus"
)

QMatrix Q = hky(
	kappa ~ LogNormal(logSd=0.5, logMean=1.0),
	baseFrequencies ~ Dirichlet(concentration=[2.0, 2.0, 2.0, 2.0]),
)
Tree tree ~ Coalescent(
	taxa = taxa(observedAlignment),
	populationSize ~ LogNormal(logMean=3.0, logSd=2.0),
)

Alignment alignment ~ PhyloCTMC(
	Q, tree
) observed as observedAlignment

// EXPECT AST
// (AS Alignment observedAlignment (CA fromNexus (AA file "alignment.nexus")))
// (AS QMatrix Q (CA hky (DA kappa (CA LogNormal (AA logSd 0.5) (AA logMean 1.0))) (DA baseFrequencies (CA Dirichlet (AA concentration (AR 2.0 2.0 2.0 2.0))))))
// (DR Tree tree (CA Coalescent (AA taxa (CA taxa (AA null observedAlignment))) (DA populationSize (CA LogNormal (AA logMean 3.0) (AA logSd 2.0)))))
// (OA (DR Alignment alignment (CA PhyloCTMC (AA null Q) (AA null tree))) observedAlignment)
