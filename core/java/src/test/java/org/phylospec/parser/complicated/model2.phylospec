data {
    String seed = env("SEED")
    Alignment molecularData = fromNexus(
        "alignment_${seed}.nex", age=parse(delimiter="_", part=1)
    )
    Alignment traitData = discreteTraitsFromTaxa(
        taxa(molecularData), trait=parse(delimiter="_", part=2)
    )
}

model {
    Tree tree ~ Yule(
        birthRate~Exponential(rate=1),
        taxa=taxa(molecularData)
    )

    QMatrix molecularQ = hky(
        kappa~LogNormal(logMean=0.1, logSd=2),
        baseFrequencies~Dirichlet([1, 1, 1, 1])
    )
    QMatrix traitQ = mk(
        rate~LogNormal(logMean=0.1, logSd=2)
    )

    Vector<Rate> siteRates ~ DiscreteGammaInv(
        shape=1,
        numCategories=4,
        invariantProportion=0.1,
        numSites=numSites(molecularData)
    )

    Vector<Rate> branchRates ~ RelaxedClock(
        LogNormal(logMean=1, logSd=2), tree
    )

    Alignment molecular ~ PhyloCTMC(
        tree, qMatrix=molecularQ, siteRates, branchRates
    ) observed as molecularData
    Alignment traits ~ PhyloCTMC(
        tree, qMatrix=traitQ, branchRates
    ) observed as traitData

    Age rootAge = rootAge(tree) observed between [1.7 yr, 4 yr]
}

mcmc {
    Integer chainLength = 100
}

// EXPECT AST
// (AS String seed (CA env (AA null "SEED")))
// (AS Alignment molecularData (CA fromNexus (AA null (ST "alignment_" seed ".nex")) (AA age (CA parse (AA delimiter "_") (AA part 1)))))
// (AS Alignment traitData (CA discreteTraitsFromTaxa (AA null (CA taxa (AA null molecularData))) (AA trait (CA parse (AA delimiter "_") (AA part 2)))))
// (DR Tree tree (CA Yule (DA birthRate (CA Exponential (AA rate 1))) (AA taxa (CA taxa (AA null molecularData)))))
// (AS QMatrix molecularQ (CA hky (DA kappa (CA LogNormal (AA logMean 0.1) (AA logSd 2))) (DA baseFrequencies (CA Dirichlet (AA null (AR 1 1 1 1))))))
// (AS QMatrix traitQ (CA mk (DA rate (CA LogNormal (AA logMean 0.1) (AA logSd 2)))))
// (DR Vector<Rate> siteRates (CA DiscreteGammaInv (AA shape 1) (AA numCategories 4) (AA invariantProportion 0.1) (AA numSites (CA numSites (AA null molecularData)))))
// (DR Vector<Rate> branchRates (CA RelaxedClock (AA null (CA LogNormal (AA logMean 1) (AA logSd 2))) (AA null tree)))
// (OA (DR Alignment molecular (CA PhyloCTMC (AA null tree) (AA qMatrix molecularQ) (AA null siteRates) (AA null branchRates))) molecularData)
// (OA (DR Alignment traits (CA PhyloCTMC (AA null tree) (AA qMatrix traitQ) (AA null branchRates))) traitData)
// (OB (AS Age rootAge (CA rootAge (AA null tree))) 1.7 yr 4 yr)
// (AS Integer chainLength 100)
