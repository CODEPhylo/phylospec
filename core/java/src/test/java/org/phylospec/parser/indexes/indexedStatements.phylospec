Vector<Real> vector = [
    10.0,
    2.0,
    -5.0
]

String i = ""

Integer vector2[i] = i*i for i in 1:num(vector)
Real matrix[i, j] = 1.0*vector2[i]*vector2[j] for i in 1:num(vector) for j in 1:5
Integer vector4[i] = 2.5*i for i in 1:num(vector)

Vector<Integer> vector5 = vector2
Vector<Real> vector6 = vector2

Real vector7[i] = 2.5*j for i in 1:10

Real x[i] ~ Normal(0.0, sd=1.0) for i in 1:10
Real y = x[1]

Real z = matrix[1, 1]
Real zz = matrix[1, -1]
Integer zzz = vector5[1, 1]

