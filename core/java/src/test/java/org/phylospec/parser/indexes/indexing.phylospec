Vector<PositiveReal> vector = [
    10.0,
    2.0,
    5.0
]

PositiveReal x = vector[2]
PositiveReal p = vector[2, 3]

Matrix<PositiveReal> matrix = [
   [10.0, 2.0],
   [10.0, 2.0],
   [10.0, 5.0],
]

PositiveReal y = matrix[2, 1]
PositiveReal z = matrix[vector[2], 1 * 100]
String w = vector[2]
String k = vector["2"]

