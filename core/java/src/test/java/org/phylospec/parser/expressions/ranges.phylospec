Integer n = 5

Vector<Integer> r1 = 1:10
Vector<Integer> r2 = 1:n
Vector<Integer> r3 = n:num(r2)
Vector<Integer> r4 = (0.5 * n):num(r2)
Real x[i] = i * 2.0 for i in 1:n

// EXPECT AST
// (AS Integer n 5)
// (AS Vector<Integer> r1 (R 1 10))
// (AS Vector<Integer> r2 (R 1 n))
// (AS Vector<Integer> r3 (R n (CA num (AA null r2))))
// (AS Vector<Integer> r4 (R (GR (* 0.5 n)) (CA num (AA null r2))))
// (IS (AS Real x (* i 2.0)) i (R 1 n))
// EXPECT AST

