// TEMPLATE
Alignment alignment ~ PhyloCTMC(
    tree=$tree,
    qMatrix=$qMatrix,
    siteRates=$siteRates
) observed as $data
// TEMPLATE

// QUERY
Alignment data = readNexus()
Tree tree ~ Yule()
Vector<Rate> siteRates = strict()
Alignment alignment ~ PhyloCTMC(
    tree,
    qMatrix=jc69(),
    siteRates
) observed as data
// QUERY

